        --_space: 2rem;

        display: grid;
        grid-auto-flow: column;
        grid-auto-columns: 98%;
        gap: var(--_space);
        overscroll-behavior-inline: contain;
        overflow-x: auto;
        overflow-y: visible;
        scroll-snap-type: inline mandatory;
        scroll-padding-inline: var(--_space);
        scrollbar-width: none;

        & > * {
          scroll-snap-align: center;
        }
        &::-webkit-scrollbar {
          display: none;
        }
