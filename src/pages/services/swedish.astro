---
import BaseLayout from 'src/layouts/BaseLayout.astro';
import landingImage from '@assets/images/landing.jpg'; // <-- THE PATH TO THE ASSET YOU WANT TO PRELOAD - The asset must live in src
import type { HeroServiceProps } from '@components/Services/ServiceHero.astro';
import { getOptimizedImage } from '@js/utils';
import ServiceHero from '@components/Services/ServiceHero.astro';
import services1Img from '@assets/images/Services-1.TherapeuticMassage.jpg';
import type { PriceBenefitsProps } from '@components/Services/PriceBenifits.astro';
import PriceBenifits from '@components/Services/PriceBenifits.astro';
import services3Img from '@assets/images/Services-3.RelaxationMassage.jpg';

const optimizedImage = await getOptimizedImage(landingImage);
export const swedishHero: HeroServiceProps = {
  title: 'Therapeutic Swedish Massage',
  image: services1Img,
  alt: 'Swedish massage with calm, flowing techniques to reduce stress',
  subtitle:
    'A calm, flowing technique that supports circulation, reduces stress, and settles the nervous system—excellent for overall wellness and relaxation.',
  highlights: [
    {
      title: 'Calming Flow',
      body: 'Gentle, rhythmic strokes help you unwind and reset.',
    },
    {
      title: 'Circulation Support',
      body: 'Promotes blood flow and general well‑being.',
    },
    {
      title: 'Full‑Body Ease',
      body: 'Ideal for those seeking a balanced, relaxing massage experience.',
    },
  ],
  ctaPrimary: { label: 'Book Swedish Session', href: '/booking' },
  ctaSecondary: { label: 'Ask a Question', href: '/contact' },
};
export const swedishData: PriceBenefitsProps = {
  benefitsTitle: 'Therapeutic Swedish Massage',
  benefits: [
    {
      num: '01',
      title: 'Whole‑body relaxation',
      body: 'Long, flowing techniques encourage a gentle release of stress and fatigue.',
    },
    {
      num: '02',
      title: 'Circulation support',
      body: 'Promotes healthy blood flow and soft‑tissue nourishment.',
    },
    {
      num: '03',
      title: 'Nervous system reset',
      body: 'Helps calm busy thoughts, improving sleep and day‑to‑day resilience.',
    },
    {
      num: '04',
      title: 'Overall wellness',
      body: 'A restorative choice for regular maintenance and self‑care.',
    },
  ],
  benefitsTagline: 'Reduce Stress, Support Circulation & Restore Calm',
  prices: [
    { duration: '45 minutes', price: '$80' },
    { duration: '60 minutes', price: '$100' },
    { duration: '90 minutes', price: '$140' },
  ],
};
---

<BaseLayout
  title="Services"
  description="Therapeutic Hot Stone Massage Edmonton - Professional Massage Therapy"
  preloadedImage={optimizedImage}
>
  <ServiceHero {...swedishHero} />
  <PriceBenifits {...swedishData} />
</BaseLayout>
